# === Auth Mode (pick one, auto-detected by priority) ===

# AI Studio mode — simplest, just an API key from aistudio.google.com
# GEMINI_API_KEY=AIzaSy...

# Service Account mode — most reliable, uses a GCP JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/app/sa.json
# SA_FILE=your-key.json

# Vertex Express mode — GCP API key, no JSON file needed
# VERTEX_API_KEY=your-google-cloud-api-key

# === Region (Service Account / Express mode) ===
# VERTEX_LOCATION=us-central1
# VERTEX_LOCATION_OVERRIDES=gemini-3*=global

# === Proxy Auth ===
# Clients must send this as Bearer token. Leave empty to allow any.
# PROXY_KEY=your-proxy-secret

# === Server ===
# PORT=8086
# BIND=0.0.0.0

# === Model Listing ===
# Comma-separated publisher list (default: google,anthropic,meta)
# PUBLISHERS=google,anthropic,meta

# Comma-separated extra model IDs to append to /v1/models
# EXTRA_MODELS=gemini-2.5-pro,gemini-2.5-flash
